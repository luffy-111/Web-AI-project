<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itluffy.mapper.OperateLogMapper">

    <select id="pageLog" resultType="com.itluffy.pojo.OperateLog">
        select ol.*,
               e.name as operate_emp_name
        from operate_log ol
                 left join emp e on ol.operate_emp_id = e.id
    </select>
</mapper>